generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "@prisma/client"
  output       = "./pothos-types.ts"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  MOVIE
  SHOW
}

enum WatchStatus {
  WANT_TO_WATCH
  WATCHING
  COMPLETED
  DROPPED
}

model Movie {
  id          String   @id @default(cuid())
  tmdbId      Int      @unique
  title       String
  overview    String
  posterPath  String?
  releaseDate String?
  runtime     Int?
  genres      String[]
  createdAt   DateTime @default(now())

  watchlistItems WatchlistItem[]
}

model Show {
  id          String   @id @default(cuid())
  tmdbId      Int      @unique
  title       String
  overview    String
  posterPath  String?
  firstAirDate String?
  genres      String[]
  createdAt   DateTime @default(now())

  watchlistItems WatchlistItem[]
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  watchlistItems WatchlistItem[]
}

model WatchlistItem {
  id        String      @id @default(cuid())
  mediaType MediaType
  status    WatchStatus
  rating    Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId  String
  movieId String?
  showId  String?

  user  User   @relation(fields: [userId], references: [id])
  movie Movie? @relation(fields: [movieId], references: [id], map: "watchlist_movie")
  show  Show?  @relation(fields: [showId], references: [id], map: "watchlist_show")
}
